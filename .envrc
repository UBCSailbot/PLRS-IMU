use flake

# Install repo-tracked hooks into .git/hooks/ so they run automatically.
# Symlinks are relative to .git/hooks/ so they survive repo moves.
for hook in hooks/*; do
  name=$(basename "$hook")
  target=".git/hooks/$name"
  if [[ ! -L "$target" ]] || [[ "$(readlink "$target")" != "../../$hook" ]]; then
    ln -sf "../../$hook" "$target"
    echo "direnv: installed git hook: $name"
  fi
done

# Auto-generate compile_commands.json when sources or config change.
# -type f + extension filter: exclude directory mtimes (which change when any
# file inside is added/removed) so only actual source edits trigger a rebuild.
# Not called from the Nix shellHook so CI (`nix develop -c ...`) stays fast.
_db_trigger=""
if [[ ! -f compile_commands.json ]]; then
  _db_trigger="compile_commands.json missing"
elif [[ platformio.ini -nt compile_commands.json ]]; then
  _db_trigger="platformio.ini changed"
else
  _db_trigger="$(find lib src test -type f \
    \( -name '*.h' -o -name '*.cpp' -o -name '*.c' \) \
    -newer compile_commands.json 2>/dev/null | head -3)"
fi
if [[ -n "$_db_trigger" ]]; then
  echo "direnv: updating compile_commands.json (trigger: $_db_trigger)"
  bash scripts/setup-compile-db.sh
fi

# Tell the NixOS clangd wrapper to skip injecting host glibc headers into
# CPLUS_INCLUDE_PATH. Without this, the wrapper unconditionally adds
# glibc-dev/include, which breaks <chrono> et al. on the ARM cross-compilation
# target (stubs.h tries to include stubs-32.h, which doesn't exist on x86_64).
# The wrapper checks $CLANGD_FLAGS alongside "$@" for --query-driver.
export CLANGD_FLAGS="--query-driver=$HOME/.platformio/packages/toolchain-rp2040-earlephilhower/bin/arm-none-eabi-g++,**/arm-none-eabi-g++,**/arm-none-eabi-gcc,**/g++"

# Inside kitty, render matplotlib plots inline via the kitty graphics
# protocol. Outside kitty (or when KITTY_WINDOW_ID is unset, e.g. tmux
# without graphics passthrough), let matplotlib auto-detect -- QtAgg
# picks up PyQt6 from the sim dev extra.
if [ -n "$KITTY_WINDOW_ID" ]; then
  # The pip package's top-level dir is hyphenated, not underscored;
  # matplotlib's module:// dispatches through importlib so it accepts
  # the hyphen form.
  export MPLBACKEND="module://matplotlib-backend-kitty"
fi
