use flake

# Install repo-tracked hooks into .git/hooks/ so they run automatically.
# Symlinks are relative to .git/hooks/ so they survive repo moves.
for hook in hooks/*; do
  name=$(basename "$hook")
  target=".git/hooks/$name"
  if [[ ! -L "$target" ]] || [[ "$(readlink "$target")" != "../../$hook" ]]; then
    ln -sf "../../$hook" "$target"
    echo "direnv: installed git hook: $name"
  fi
done

# Auto-generate compile_commands.json and .clangd if platformio.ini is newer
if [[ ! -f compile_commands.json ]] || [[ platformio.ini -nt compile_commands.json ]]; then
  echo "Updating compilation database and .clangd..."
  pio run -t compiledb
fi

# Tell the NixOS clangd wrapper to skip injecting host glibc headers into
# CPLUS_INCLUDE_PATH. Without this, the wrapper unconditionally adds
# glibc-dev/include, which breaks <chrono> et al. on the ARM cross-compilation
# target (stubs.h tries to include stubs-32.h, which doesn't exist on x86_64).
# The wrapper checks $CLANGD_FLAGS alongside "$@" for --query-driver.
export CLANGD_FLAGS="--query-driver=$HOME/.platformio/packages/toolchain-rp2040-earlephilhower/bin/arm-none-eabi-g++,**/arm-none-eabi-g++,**/arm-none-eabi-gcc,**/g++"
